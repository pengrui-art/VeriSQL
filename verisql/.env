# VeriSQL Environment Configuration
# 请将此文件重命名为 .env 并填写你的 API Key

# ============== LLM Provider 选择 ==============

# 选择 LLM 提供商: openai, deepseek, qwen
LLM_PROVIDER=qwen

# ============== API Keys (根据你选择的 Provider 填写) ==============

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek API Key (推荐，性价比高)
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Qwen/通义千问 API Key (阿里云 DashScope)
# 获取地址: https://dashscope.console.aliyun.com/
# 注意: 环境变量名必须是 DASHSCOPE_API_KEY
DASHSCOPE_API_KEY=sk-f8bdcf56800f4de9bea7b1081611eac9

# ============== Model Selection (可选，有默认值) ==============

# SQL 生成模型
# - OpenAI: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# - DeepSeek: deepseek-chat, deepseek-coder
# - Qwen 有效模型: glm-4.7, kimi-k2.5, MiniMax-M2.1,qwen3-vl-plus-2025-12-19, qwen3-max-2026-01-23, MiniMax-M2.5, qwen3.5-397b-a17b, qwen3.5-122b-a10b, qwen3.5-plus
SQL_MODEL=qwen3.5-plus

# Spec 生成模型 (可以与 SQL_MODEL 不同，降低双重幻觉风险)
SPEC_MODEL=qwen3.5-plus

# ============== Verification Settings ==============

# Z3 solver timeout in milliseconds
Z3_TIMEOUT_MS=5000

# Maximum repair iterations before giving up
MAX_REPAIR_ITERATIONS=3

# Verification mode: "strict" or "lenient"
VERIFICATION_MODE=strict

# ============== Database Settings ==============

# Default SQL dialect (sqlite, mysql, postgresql, etc.)
DEFAULT_DIALECT=sqlite

# ============== Logging ==============

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============== Advanced Settings ==============
# Enable streaming mode (Required for some models like GLM-4)
LLM_STREAMING=true
